{
  "name": "vscode-openapify",
  "displayName": "OpenAPI (Swagger) Viewer",
  "description": "A VS Code extension for viewing OpenAPI specs to streamline API development.",
  "version": "1.0.0",
  "license": "MIT",
  "private": "true",
  "publisher": "mumincelal",
  "homepage": "https://github.com/mumincelal/vscode-openapi",
  "repository": {
    "type": "git",
    "url": "https://github.com/mumincelal/vscode-openapi.git"
  },
  "bugs": {
    "url": "https://github.com/mumincelal/vscode-openapi/issues"
  },
  "engines": {
    "vscode": "1.108.1"
  },
  "extensionDependencies": [
    "redhat.vscode-yaml"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "vscode",
    "openapi",
    "swagger",
    "api",
    "development",
    "preview"
  ],
  "main": "./out/extension.js",
  "icon": "images/logo.png",
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:yaml",
    "onLanguage:yml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-openapify.preview",
        "category": "VSCode OpenAPI",
        "title": "Preview Swagger File"
      },
      {
        "command": "vscode-openapify.refreshTreeView",
        "category": "VSCode OpenAPI",
        "title": "Refresh OpenAPI Explorer",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openapiExplorerContainer",
          "title": "OpenAPI Explorer",
          "icon": "$(symbol-interface)"
        }
      ]
    },
    "views": {
      "openapiExplorerContainer": [
        {
          "id": "openapiExplorer",
          "name": "Structure",
          "icon": "",
          "when": "resourceLangId == json || resourceLangId == yaml || resourceLangId == yml"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vscode-openapify.refreshTreeView",
          "when": "view == openapiExplorer",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == json",
          "command": "vscode-openapify.preview",
          "group": "OpenAPIViewer"
        },
        {
          "when": "resourceLangId == yaml",
          "command": "vscode-openapify.preview",
          "group": "OpenAPIViewer"
        },
        {
          "when": "resourceLangId == yml",
          "command": "vscode-openapify.preview",
          "group": "OpenAPIViewer"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "*.json",
        "url": "./schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "rimraf out && tsc -p ./",
    "build": "rimraf out && tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "tsc -p ./ && biome lint --write",
    "semantic-release": "semantic-release",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "migrate": "biome migrate --write",
    "test": "vscode-test",
    "prepare": "husky"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.4.0",
    "@apidevtools/swagger-parser": "^12.1.0",
    "express": "^5.2.1",
    "js-yaml": "^5.1.0",
    "socket.io": "^4.8.3",
    "swagger-ui-dist": "^5.32.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.125.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "semantic-release-vsce": "^6.1.5",
    "typescript": "^6.0.3"
  }
}
